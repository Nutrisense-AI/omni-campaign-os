# ============ Supabase ============
# Project Settings -> API. Use the LEGACY JWT keys (anon + service_role).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-jwt...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-jwt...

# ============ AI: Text (Anthropic Claude) ============
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ============ AI: Images (OpenAI) ============
OPENAI_API_KEY=sk-proj-...
OPENAI_IMAGE_MODEL=gpt-image-1

# ============ AI: Voice (ElevenLabs) ============
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# ============ Video (Shotstack) ============
SHOTSTACK_API_KEY=your-production-v1-key
SHOTSTACK_ENV=v1
SHOTSTACK_STAGE_KEY=your-stage-key

# ============ Email (Resend) ============
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev

# ============ Payments (Stripe) ============
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ============ App ============
# Set to your Vercel production URL after deploy, e.g. https://omni-campaign.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# A random secret string used to authorize cron endpoints
CRON_SECRET=generate_a_long_random_string
